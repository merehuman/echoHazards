# Copy this to .env and fill in values
# Never commit .env to git

DATABASE_URL=postgresql://tp_user:tp_password@localhost:5432/echo_hazards

# EPA ECHO API (no key required, but set a descriptive user-agent)
ECHO_API_BASE=https://echo.epa.gov/Rest/api
ECHO_USER_AGENT=echoHazards/1.0 (github.com/yourname/echo-hazards)

# NRC data — bulk CSV download location
NRC_DATA_DIR=./data/nrc

# Pipeline settings
INGEST_BATCH_SIZE=500
ECHO_RATE_LIMIT_DELAY=1.0

# App
LOG_LEVEL=INFO
ENVIRONMENT=development
